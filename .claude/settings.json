{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/credentials)",
      "Read(**/credentials.json)",
      "Read(**/.aws/credentials)",
      "Read(./rag/.chroma/**)",
      "Read(./rag/.bm25/**)",
      "Read(./rag/.chroma_panel/**)"
    ]
  }
}
