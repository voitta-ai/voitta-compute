# Voitta Compute — server/operator config. Copy to .env on the server.
# Read by app.config via python-dotenv. NOT shipped in the macOS bundle and
# absent in dev, so these only take effect on a server deployment.
# Existing environment variables always win (load_dotenv does not override).

# ── Where mutable data lives (uploads, conversations DB, RAG, auth secret) ──
# Defaults to the macOS Application Support dir; set a real path on Linux.
VOITTA_DATA_ROOT=/home/youruser/.local/share/voitta

# ── Login guard: "Sign in with Google" ─────────────────────────────────────
# Setting BOTH of these turns the guard ON (server mode only). Anyone who can
# complete Google sign-in is allowed (no email allow-list yet).
# The redirect URI is {VOITTA_PUBLIC_BASE_URL}/api/auth/google/callback and
# MUST be registered for this OAuth client in the Google Cloud console.
VOITTA_GOOGLE_AUTH_CLIENT_ID=
VOITTA_GOOGLE_AUTH_CLIENT_SECRET=

# Public base URL the server is reached at (used to build the OAuth redirect).
VOITTA_PUBLIC_BASE_URL=https://your-domain.example

# Optional: HMAC key for signing session cookies. If unset, a random key is
# generated and persisted to {VOITTA_DATA_ROOT}/auth_secret so sessions
# survive restarts. Set explicitly to share sessions across instances.
# VOITTA_AUTH_SECRET=
