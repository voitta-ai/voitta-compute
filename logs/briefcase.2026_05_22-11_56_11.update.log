pyproject.toml:
# Repo-root briefcase manifest.
#
# briefcase reads pyproject.toml from CWD and writes build/ + dist/ next
# to it, so this file lives at the repo root. Backend Python deps and
# tests still live in backend/pyproject.toml; this file is briefcase-only.
#
# build_app.sh cd's here before invoking briefcase, using the same
# backend/.venv that build.sh set up.

[tool.briefcase]
project_name = "Voitta"
bundle = "ai.voitta"
version = "0.1.1"
url = "https://voitta.ai"
license = "AGPL-3.0-or-later"
license-files = ["LICENSE"]
author = "Voitta"
author_email = "info@voitta.ai"

[tool.briefcase.app.voitta-chainlit]
# formal_name → .app filename ("Voitta Chainlit.app") and DMG name.
# The table key ("voitta-chainlit") becomes the build-dir slug.
formal_name = "Voitta Chainlit"
description = "Local Chainlit-based AI assistant with bookmarklet injection."
icon = "icons/voitta"
long_description = """
Voitta Chainlit runs a local Chainlit + FastAPI backend accessible via
a browser bookmarklet on any HTTPS page. macOS menu-bar shell, no Dock icon.
"""

# Paths relative to this pyproject.toml (repo root).
# - src/voitta_chainlit  : briefcase shim + bundled resources
# - backend/app          : the actual application code
# - scripts              : build_rag.py (importable by app.rag_build at runtime)
sources = [
    "src/voitta_chainlit",
    "backend/app",
    "scripts",
]

# Run-time deps shipped INSIDE the bundle. Heavy scientific packages
# (scipy, pandas, matplotlib, plotly, chromadb) are NOT here — they are
# pip-installed on first launch into ~/Library/Application Support/Voitta Chainlit/
# userbase/ by app.installer. This keeps the bundle under ~350 MB.
#
# pip + setuptools + wheel are bundled so the first-run installer can call
# pip._internal.cli.main without bootstrapping.
requires = [
    # Server
    "fastapi>=0.115",
    "uvicorn[standard]>=0.30",
    "pydantic>=2.7",
    "httpx>=0.27",
    # NOTE: chainlit is NOT listed here. It and its transitive deps
    # (syncer, lazify, literalai — all removed from / never on PyPI)
    # are installed into app_packages by build_app.sh step 6b after
    # briefcase create, using "pip install --find-links ./wheels".
    # Adding chainlit here causes briefcase's "--only-binary :all:
    # --platform macosx_14_0_arm64" pip call to fail on syncer.
    # LLM providers
    "anthropic>=0.39",
    "openai>=1.50",
    "google-genai>=0.3",
    # MCP (imports at module load, before installer can run)
    "fastmcp>=2.0",
    # RAG sparse index — lightweight, no C extensions
    "bm25s>=0.2.6",
    "PyStemmer>=2.2.0",
    # Utilities
    "numpy>=1.26",
    "pillow>=10.0",
    "pypdf>=5.0",
    "python-multipart",
    # macOS menu-bar
    "./wheels/rumps-0.4.0-py3-none-any.whl",
    "pyobjc-framework-Cocoa>=10.0",
    # Installer bootstrap
    "pip",
    "setuptools",
    "wheel",
]

[tool.briefcase.app.voitta-chainlit.macOS]
# arm64 only — universal2 doubles bundle size and scientific wheels
# default to arm64-only anyway.
universal_build = false
# Sonoma is Apple's current security floor and the minimum for
# the scientific stack wheels we lazy-install.
min_os_version = "14.0"
# LSUIElement = menu-bar only, no Dock icon.
info."LSUIElement" = true
info."NSHumanReadableCopyright" = "© Voitta"

# ---- hardened runtime entitlements (required for notarisation) ----------
#
# • allow-jit: Python bytecode mprotects RWX pages; killed without this.
# • allow-unsigned-executable-memory: catches the same in C extensions.
# • disable-library-validation: we vendor ~80 C extensions signed by
#   their wheel builders, not by our team ID. Standard Python-app pattern.
# • allow-dyld-environment-variables: briefcase stub sets DYLD_FRAMEWORK_PATH
#   so the bundled Python.framework is preferred; hardened runtime strips
#   DYLD_* vars by default.
entitlement."com.apple.security.cs.allow-jit" = true
entitlement."com.apple.security.cs.allow-unsigned-executable-memory" = true
entitlement."com.apple.security.cs.disable-library-validation" = true
entitlement."com.apple.security.cs.allow-dyld-environment-variables" = true

