# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Operator secrets (server deployments). Committed template: .env.example
.env

# Node / Vite
node_modules/
frontend/dist/

# Built RAG indexes (rebuildable via `python scripts/build_rag.py`).
# Leading slash anchors to the repo root — without it, `rag/` also
# matches backend/app/tools/rag/ and silently drops the runtime
# package from git.
/rag/

# Chainlit session/translations cache
.chainlit/
.files/

# python_storage (runtime artefact cache, populated by report scripts)
python_storage/

# Script state (per-run render events; not source)
scripts_state/

# Build-generated resource staging (populated by build_app.sh step 5).
# Master copies live in docs/, plugins/, frontend/ — never edit under resources/.
src/voitta_compute/resources/docs/
src/voitta_compute/resources/frontend_dist/
src/voitta_compute/resources/plugins/
src/voitta_compute/resources/vendor_js/

# Build artifacts / release binaries
dist/
wheels/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Claude Code local state (scheduled task lock, etc).
.claude/
build/
