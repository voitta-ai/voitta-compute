# env / secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
*.egg

# RAG indexes (rebuildable from docs/ via rag/build_rag.py and from
# libs-info/panel/ via rag/build_panel_rag.py)
rag/.chroma/
rag/.bm25/
rag/.chroma_panel/
rag/.bm25_panel/

# Server-side snapshot cache (provider download tools, e.g.
# drive_download_to_python_storage)
python_storage/

# User-defined Python scripts (run_compute + define_report tools).
# Ignore *contents* (not the dirs themselves) so individual adapters
# can be re-included with !-patterns below.
scripts/compute/*
scripts/reports/*
# Shipped adapters that wrap permanent backend modules.
!scripts/compute/a4db_parse/
!scripts/reports/a4db_3d/

# TLS material
backend/certs/*.pem

# Frontend build artefacts (when the frontend lands)
frontend/node_modules/
frontend/dist/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
